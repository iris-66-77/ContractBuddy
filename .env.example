# 一纸穿透 - 合同霸王条款识别工具
# 配置说明：复制此文件为.env，并填入你的真实配置

# DeepSeek API密钥（用于合同分析）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# SerpAPI密钥（用于网页搜索）
# 获取地址：https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# 本地PaddleOCR服务配置
USE_LOCAL_PADDLE_OCR=true
PADDLE_OCR_URL=http://localhost:8866/api/ocr

# 服务器端口
PORT=3000

# ================== 文件存储配置 ==================
# 当前仅支持本地存储（文件保存在 data/uploads/ 目录下）
STORAGE_TYPE=local
